{
  "$schema": "node_modules/wrangler/config-schema.json",

  "name": "unit",
  "main": "src/index.ts",

  "compatibility_date": "2026-05-30",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],

  "assets": {
    "directory": "./public"
  },

  "observability": {
    "enabled": true
  },

  "upload_source_maps": true,

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "prod",
      "database_id": "87bdbda2-64c9-40f9-9b1b-4fb6bda9b70f"
    }
  ]
}
